# Required for POST /ask (Groq Llama chat)
GROQ_API_KEY=

# Optional: absolute or relative path to the knowledge base folder (defaults to ./fastcite_knowledge_base)
# KB_PATH=

# Optional: embeddings & memory tuning (hosts with limited RAM, e.g. Render free tier)
# FASTCITE_EMBED_MODEL=all-MiniLM-L6-v2
# FASTCITE_ST_BATCH=16
# TORCH_NUM_THREADS=2
